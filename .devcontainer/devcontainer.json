{
  "name": "Slidev Export",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "PLAYWRIGHT_DOWNLOAD_CONNECTION_TIMEOUT": "300000"
  },
  "postCreateCommand": "npm install && npx playwright install chromium",
  "customizations": {
    "vscode": {
      "extensions": [
        "antfu.slidev"
      ]
    }
  },
  "forwardPorts": [3030],
  "portsAttributes": {
    "3030": {
      "label": "Slidev",
      "onAutoForward": "openBrowser"
    }
  }
}
